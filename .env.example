# ==============================================
# LLM Honeypot Configuration
# ==============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- LLM Provider ---
# Options: openai, ollama
LLM_PROVIDER=openai

# --- OpenAI Settings ---
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Ollama Settings (if using local LLM) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3

# --- General LLM Settings ---
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# --- Honeypot Ports ---
COWRIE_SSH_PORT=2224
COWRIE_TELNET_PORT=2223

# --- Project Branding ---
PROJECT_NAME=LLM-Honeypot-Webui
AUTHOR=Jaime Acosta

# --- WebUI Port ---
WEBUI_PORT=8080
